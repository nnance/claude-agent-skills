{
	"compilerOptions": {
		"rootDir": "./src",

		"module": "es2022",
		"target": "esnext",
		"moduleResolution": "bundler",
		"lib": ["esnext"],
		"types": ["node"],

		"strict": true,
		"jsx": "react-jsx",
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	}
}
